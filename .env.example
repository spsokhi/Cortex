# Cortex Environment Configuration
# Copy this to .env and customize as needed.
# The desktop app reads VITE_* variables at build time.
# Python services read variables at runtime.

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_APP_VERSION=0.1.0
VITE_OLLAMA_ENDPOINT=http://localhost:11434

# ─── Python services ─────────────────────────────────────────────────────────
# Embeddings service
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDINGS_PORT=8001

# Whisper service
WHISPER_MODEL=base
WHISPER_DEVICE=auto        # auto | cpu | cuda
WHISPER_COMPUTE_TYPE=auto  # auto | int8 | float16
WHISPER_PORT=8002

# RAG service
RAG_PORT=8003
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── Debug ────────────────────────────────────────────────────────────────────
TAURI_DEBUG=false
RUST_LOG=warn
